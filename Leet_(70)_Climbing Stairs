class Solution {
public:
    int climbStairs(int n) {
        if(n <= 2)
        {
            return n;
        }

        int firstNum = 1;
        int secondNum = 2;
        int result = 0;

        for(int i = 3; i <= n; i++)
        {
            result = firstNum + secondNum;
            firstNum = secondNum;
            secondNum = result;
        }

        return result;
    }
};
